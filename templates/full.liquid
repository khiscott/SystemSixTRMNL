{% comment %}
  SystemSix TRMNL — a retro Macintosh desktop for your e-ink display.
  Inspired by https://github.com/EngineersNeedArt/SystemSix
  Three layouts rotate daily, matching the original's variance.
  Weather: Open-Meteo  |  Assets: jsDelivr CDN
{% endcomment %}

{% assign CDN = "https://cdn.jsdelivr.net/gh/khiscott/SystemSixTRMNL@main/assets" %}

{% comment %} ═══════ DATE ═══════ {% endcomment %}
{% assign day_of_year = "now" | date: "%-j" | plus: 0 %}
{% assign day_of_week = "now" | date: "%u"  | plus: 0 %}
{% assign day_name    = "now" | date: "%A" %}
{% assign month_name  = "now" | date: "%B" %}
{% assign day_num     = "now" | date: "%-d" %}
{% assign year_num    = "now" | date: "%Y" %}
{% assign date_str    = day_name | append: ", " | append: month_name | append: " " | append: day_num | append: ", " | append: year_num %}

{% comment %} ═══════ MOON PHASE ═══════ {% endcomment %}
{% assign unix_day      = "now" | date: "%s" | plus: 0 | divided_by: 86400 %}
{% assign phase_raw     = unix_day | minus: 6 | times: 100 | modulo: 2953 %}
{% assign moon_phase    = phase_raw | divided_by: 100 | plus: 1 %}
{% if moon_phase > 29 %}{% assign moon_phase = 0 %}{% endif %}
{% assign moon_img_idx  = moon_phase | times: 24 | divided_by: 29 %}
{% if moon_img_idx > 23 %}{% assign moon_img_idx = 0 %}{% endif %}
{% if moon_phase == 0 or moon_phase == 30 %}{% assign moon_label = "New Moon" %}
{% elsif moon_phase < 8 %}{% assign moon_label = "Waxing Crescent" %}
{% elsif moon_phase == 15 %}{% assign moon_label = "Full Moon" %}
{% elsif moon_phase < 15 %}{% assign moon_label = "Waxing Gibbous" %}
{% elsif moon_phase < 23 %}{% assign moon_label = "Waning Gibbous" %}
{% else %}{% assign moon_label = "Waning Crescent" %}{% endif %}

{% comment %} ═══════ TRASH DAY ═══════ {% endcomment %}
{% assign trash_setting = trmnl.plugin_settings.custom_fields_values.trash_day | plus: 0 %}
{% if trash_setting > 0 and trash_setting == day_of_week %}{% assign trash_full = true %}{% else %}{% assign trash_full = false %}{% endif %}

{% comment %} ═══════ WEATHER (Open-Meteo nested JSON) ═══════ {% endcomment %}
{% assign temp  = current.temperature_2m | round %}
{% assign wcode = current.weather_code | plus: 0 %}
{% if wcode == 0 %}{% assign wx = "Clear" %}
{% elsif wcode <= 2 %}{% assign wx = "Partly Cloudy" %}
{% elsif wcode == 3 %}{% assign wx = "Overcast" %}
{% elsif wcode <= 49 %}{% assign wx = "Fog" %}
{% elsif wcode <= 59 %}{% assign wx = "Drizzle" %}
{% elsif wcode <= 69 %}{% assign wx = "Rain" %}
{% elsif wcode <= 79 %}{% assign wx = "Snow" %}
{% elsif wcode <= 86 %}{% assign wx = "Showers" %}
{% else %}{% assign wx = "Thunderstorm" %}{% endif %}
{% assign temp_unit = trmnl.plugin_settings.custom_fields_values.temperature_unit %}
{% if temp_unit == "celsius" %}{% assign unit = "°C" %}{% else %}{% assign unit = "°F" %}{% endif %}

{% comment %} Daily forecast (if polling URL includes &daily=...) {% endcomment %}
{% assign d_max = daily.temperature_2m_max %}
{% assign d_min = daily.temperature_2m_min %}
{% assign today_hi  = d_max[0] | round %}
{% assign today_lo  = d_min[0] | round %}
{% assign tmrw_hi   = d_max[1] | round %}
{% assign tmrw_lo   = d_min[1] | round %}
{% assign day3_hi   = d_max[2] | round %}
{% assign day3_lo   = d_min[2] | round %}

{% comment %} ═══════ LAYOUT SELECTION (matches original weighting: A=5/7, B=1/7, C=1/7) ═══════ {% endcomment %}
{% assign layout_seed = day_of_year | modulo: 7 %}
{% if layout_seed == 0 %}{% assign layout = "B" %}
{% elsif layout_seed == 1 %}{% assign layout = "C" %}
{% else %}{% assign layout = "A" %}{% endif %}

{% comment %} ═══════ ICON CATEGORY (weighted by count, like original) ═══════ {% endcomment %}
{% assign icon_seed = day_of_year | modulo: 147 %}
{% if icon_seed < 10 %}{% assign icon_cat = "art" %}{% assign icon_max = 10 %}{% assign win_title = "Art" %}
{% elsif icon_seed < 20 %}{% assign icon_cat = "dev" %}{% assign icon_max = 10 %}{% assign win_title = "Development" %}
{% elsif icon_seed < 109 %}{% assign icon_cat = "game" %}{% assign icon_max = 89 %}{% assign win_title = "Games" %}
{% elsif icon_seed < 119 %}{% assign icon_cat = "office" %}{% assign icon_max = 10 %}{% assign win_title = "Office" %}
{% elsif icon_seed < 136 %}{% assign icon_cat = "sys" %}{% assign icon_max = 17 %}{% assign win_title = "System" %}
{% else %}{% assign icon_cat = "util" %}{% assign icon_max = 11 %}{% assign win_title = "Utilities" %}{% endif %}

{% comment %} Pick 6 icons from category {% endcomment %}
{% assign ioff = day_of_year | times: 7 | modulo: icon_max %}
{% assign ic0 = ioff | modulo: icon_max %}
{% assign ic1 = ioff | plus: 1 | modulo: icon_max %}
{% assign ic2 = ioff | plus: 2 | modulo: icon_max %}
{% assign ic3 = ioff | plus: 3 | modulo: icon_max %}
{% assign ic4 = ioff | plus: 4 | modulo: icon_max %}
{% assign ic5 = ioff | plus: 5 | modulo: icon_max %}

{% comment %} ═══════ DAILY VARIANCE ═══════ {% endcomment %}
{% comment %} Cairo adornments (5 pair combos, rotated weekly) {% endcomment %}
{% assign adorn = day_of_year | divided_by: 7 | modulo: 5 %}
{% if adorn == 0 %}{% assign cairo_l = "cairo_0" %}{% assign cairo_r = "cairo_1" %}
{% elsif adorn == 1 %}{% assign cairo_l = "cairo_3" %}{% assign cairo_r = "cairo_2" %}
{% elsif adorn == 2 %}{% assign cairo_l = "cairo_4" %}{% assign cairo_r = "cairo_4" %}
{% elsif adorn == 3 %}{% assign cairo_l = "cairo_5" %}{% assign cairo_r = "cairo_6" %}
{% else %}{% assign cairo_l = "cairo_7" %}{% assign cairo_r = "cairo_8" %}{% endif %}

{% comment %} Startup disk: black or white {% endcomment %}
{% assign disk_flavor = day_of_year | modulo: 2 %}

{% comment %} Arrow cursor position (seeded pseudo-random) {% endcomment %}
{% assign cx = day_of_year | times: 37 | plus: 13 | modulo: 500 | plus: 140 %}
{% assign cy = day_of_year | times: 53 | plus: 7  | modulo: 300 | plus: 60 %}

{% comment %} ═══════ SCREEN SCALING (TRMNL X support) ═══════ {% endcomment %}
{% assign screen_w = trmnl.screen.width | default: 800 | plus: 0 %}
{% assign screen_h = trmnl.screen.height | default: 480 | plus: 0 %}
{% assign scale_x = screen_w | times: 1000 | divided_by: 800 %}
{% assign scale_y = screen_h | times: 1000 | divided_by: 480 %}
{% if scale_x < scale_y %}{% assign scale_k = scale_x %}{% else %}{% assign scale_k = scale_y %}{% endif %}
{% assign scale_whole = scale_k | divided_by: 1000 %}
{% assign scale_frac = scale_k | modulo: 1000 %}
{% assign scale_frac_str = scale_frac | prepend: "000" | slice: -3, 3 %}

{% comment %} DA: show moon when visible (phase > 0), else puzzle or calculator {% endcomment %}
{% if moon_img_idx > 0 %}{% assign show_moon = true %}{% else %}{% assign show_moon = false %}{% endif %}
{% assign da_alt = day_of_year | modulo: 2 %}

<style>
  @font-face { font-family: 'Chicago'; src: url('{{ CDN }}/fonts/ChiKareGo2.ttf') format('truetype'); }
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body, .screen {
    width: 800px; height: 480px;
    overflow: hidden; background: #fff;
    font-family: 'Chicago', monospace;
    position: relative;
  }

  /* ── Menu Bar ── */
  .menubar {
    position: absolute; top: 0; left: 0; right: 0; height: 20px;
    background: #fff; border-bottom: 1.5px solid #000;
    display: flex; align-items: center;
    padding: 0 8px; gap: 14px; z-index: 100;
  }
  .menubar span { font-size: 12px; }
  .menubar__apple { font-size: 14px; font-weight: bold; }

  /* ── Desktop ── */
  .desktop { position: absolute; top: 21px; left: 0; right: 0; bottom: 0; background: #fff; }

  /* ── Mac Window Chrome ── */
  .win {
    position: absolute; border: 1.5px solid #000; background: #fff;
  }
  .win-tb {
    height: 18px;
    background: repeating-linear-gradient(to bottom, #000 0px, #000 1px, #fff 1px, #fff 2px);
    display: flex; align-items: center; position: relative;
  }
  .win-close {
    width: 11px; height: 11px; border: 1.5px solid #000; background: #fff;
    flex-shrink: 0; margin-left: 4px;
  }
  .win-t {
    position: absolute; left: 50%; transform: translateX(-50%);
    background: #fff; padding: 0 6px; font-size: 11px; white-space: nowrap; line-height: 18px;
  }

  /* ── Scrapbook window (Layout A) ── */
  .scrapbook { width: 420px; }
  .scrapbook-body { padding: 0; position: relative; }
  .scrapbook-scroll {
    position: absolute; right: 0; top: 0; bottom: 0; width: 16px;
    border-left: 1.5px solid #000;
    background: repeating-linear-gradient(to bottom, #fff 0px, #fff 1px, #ccc 1px, #ccc 2px);
  }
  .scrapbook-scroll-up, .scrapbook-scroll-dn {
    position: absolute; left: 0; right: 0; height: 16px;
    border: 1px solid #000; background: #fff; display: flex;
    align-items: center; justify-content: center; font-size: 8px;
  }
  .scrapbook-scroll-up { top: 0; }
  .scrapbook-scroll-dn { bottom: 0; }
  .scrapbook-content { margin-right: 18px; padding: 6px 10px 10px; }
  .scrapbook-date {
    text-align: center; font-size: 12px; padding: 6px 0 2px;
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  .scrapbook-date img { width: 24px; height: auto; image-rendering: pixelated; }
  .scrapbook-divider { border: none; border-top: 1px solid #000; margin: 6px 0; }
  .scrapbook-forecast { font-size: 10px; line-height: 1.7; }

  /* ── Paint window (Layout B) ── */
  .paint { width: 540px; }
  .paint-toolbar {
    width: 32px; position: absolute; left: 0; top: 18px; bottom: 0;
    border-right: 1.5px solid #000; background: #eee;
  }
  .paint-body { margin-left: 34px; padding: 12px; }
  .paint-date { font-size: 14px; text-align: center; margin-bottom: 8px; }
  .paint-temp { font-size: 48px; text-align: center; font-weight: bold; line-height: 1; }
  .paint-wx { font-size: 12px; text-align: center; margin-top: 4px; }
  .paint-forecast { font-size: 10px; line-height: 1.7; margin-top: 12px; padding-top: 8px; border-top: 1px solid #000; }

  /* ── Write window (Layout C) ── */
  .write { width: 480px; }
  .write-ruler {
    height: 12px; border-bottom: 1.5px solid #000;
    background: repeating-linear-gradient(to right, #000 0px, #000 1px, transparent 1px, transparent 8px);
    background-size: 8px 6px; background-position: 0 bottom; background-repeat: repeat-x;
  }
  .write-body { padding: 10px 14px; }
  .write-line { font-size: 11px; line-height: 1.8; }
  .write-title-line { font-size: 12px; font-weight: bold; margin-bottom: 6px; }

  /* ── Icon 3×2 window ── */
  .icon-win { width: 280px; }
  .icon-row { display: flex; justify-content: space-around; }
  .icon-cell {
    display: flex; flex-direction: column; align-items: center;
    width: 80px; padding: 6px 0;
  }
  .icon-cell img { width: 40px; height: 40px; image-rendering: pixelated; }

  /* ── Moon DA ── */
  .moon-da { width: 140px; }
  .moon-da-body { display: flex; align-items: center; padding: 6px 8px; gap: 8px; }
  .moon-da-body img { width: 52px; height: 52px; image-rendering: pixelated; flex-shrink: 0; }
  .moon-da-text { font-size: 9px; line-height: 1.5; }

  /* ── Puzzle / Calculator DA ── */
  .da-img { image-rendering: pixelated; display: block; }

  /* ── Startup Disk ── */
  .startup-disk {
    position: absolute; display: flex; flex-direction: column; align-items: center;
  }
  .startup-disk img { width: 40px; height: 40px; image-rendering: pixelated; }

  /* ── Trash ── */
  .trash {
    position: absolute; bottom: 8px; right: 14px;
    display: flex; flex-direction: column; align-items: center;
  }
  .trash img { width: 36px; height: 36px; image-rendering: pixelated; }

  /* ── Arrow Cursor ── */
  .cursor {
    position: absolute; z-index: 50; pointer-events: none;
  }
  .cursor img { width: 20px; height: 20px; image-rendering: pixelated; }

  /* ── Labels ── */
  .lbl { font-size: 9px; text-align: center; margin-top: 2px; white-space: nowrap; }

</style>

<div class="screen" style="transform: scale({{ scale_whole }}.{{ scale_frac_str }}); transform-origin: top left;">

<!-- ── Menu Bar ── -->
<div class="menubar">
  <span class="menubar__apple">&#63743;</span>
  <span>File</span>
  <span>Edit</span>
  <span>View</span>
  <span>Special</span>
</div>

<div class="desktop">

  <!-- ── Startup Disk (top-right, always) ── -->
  <div class="startup-disk" style="top:8px; right:14px;">
    {% if disk_flavor == 0 %}
      <img src="{{ CDN }}/disk_black.png" alt="SystemSix">
    {% else %}
      <img src="{{ CDN }}/disk_white.png" alt="SystemSix">
    {% endif %}
    <span class="lbl">System Six</span>
  </div>

  <!-- ── Trash (bottom-right, always) ── -->
  <div class="trash">
    {% if trash_full %}
      <img src="{{ CDN }}/trash_full.png" alt="Trash">
    {% else %}
      <img src="{{ CDN }}/trash.png" alt="Trash">
    {% endif %}
    <span class="lbl">Trash</span>
  </div>

  <!-- ── Arrow Cursor ── -->
  <div class="cursor" style="left:{{ cx }}px; top:{{ cy }}px;">
    <img src="{{ CDN }}/arrow_cursor.png" alt="">
  </div>

{% comment %} ════════════════════════════════════════════════════
   LAYOUT A — Scrapbook (left) + Icon Window (right) + Moon DA (bottom-left)
   Shown 5 of 7 days. The classic SystemSix look.
   ════════════════════════════════════════════════════ {% endcomment %}
{% if layout == "A" %}

  <!-- Scrapbook Window -->
  <div class="win scrapbook" style="top:14px; left:14px;">
    <div class="win-tb">
      <div class="win-close"></div>
      <span class="win-t">Scrapbook</span>
    </div>
    <div class="scrapbook-body">
      <div class="scrapbook-scroll">
        <div class="scrapbook-scroll-up">▲</div>
        <div class="scrapbook-scroll-dn">▼</div>
      </div>
      <div class="scrapbook-content">
        <div class="scrapbook-date">
          <img src="{{ CDN }}/icons/{{ cairo_l }}.png" alt="">
          <span>{{ date_str }}</span>
          <img src="{{ CDN }}/icons/{{ cairo_r }}.png" alt="">
        </div>
        <hr class="scrapbook-divider">
        <div class="scrapbook-forecast">
          Now: {{ temp }}{{ unit }}, {{ wx }}<br>
          Today: High {{ today_hi }}° / Low {{ today_lo }}°<br>
          Tomorrow: High {{ tmrw_hi }}° / Low {{ tmrw_lo }}°
        </div>
      </div>
    </div>
  </div>

  <!-- Icon Window (3×2) -->
  <div class="win icon-win" style="top:60px; right:70px;">
    <div class="win-tb">
      <div class="win-close"></div>
      <span class="win-t">{{ win_title }}</span>
    </div>
    <div class="icon-row">
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic0 }}.png" alt=""></div>
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic1 }}.png" alt=""></div>
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic2 }}.png" alt=""></div>
    </div>
    <div class="icon-row">
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic3 }}.png" alt=""></div>
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic4 }}.png" alt=""></div>
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic5 }}.png" alt=""></div>
    </div>
  </div>

  <!-- Moon DA or Puzzle/Calculator -->
  {% if show_moon %}
  <div class="win moon-da" style="bottom:14px; left:14px;">
    <div class="win-tb">
      <div class="win-close"></div>
      <span class="win-t">Moon Phase</span>
    </div>
    <div class="moon-da-body">
      <img src="{{ CDN }}/moon/moon{{ moon_img_idx }}.png" alt="{{ moon_label }}">
      <div class="moon-da-text">{{ moon_label }}<br>Day {{ moon_phase }} of 29</div>
    </div>
  </div>
  {% elsif da_alt == 0 %}
  <img class="da-img" src="{{ CDN }}/puzzle.png" alt="Puzzle" style="position:absolute; bottom:14px; left:14px; width:91px; height:auto; image-rendering:pixelated;">
  {% else %}
  <img class="da-img" src="{{ CDN }}/calculator.png" alt="Calculator" style="position:absolute; bottom:14px; left:14px; width:106px; height:auto; image-rendering:pixelated;">
  {% endif %}

{% comment %} ════════════════════════════════════════════════════
   LAYOUT B — Paint Window (large, date-focused) + smaller weather + Moon DA
   Shown 1 of 7 days. Dramatic date display.
   ════════════════════════════════════════════════════ {% endcomment %}
{% elsif layout == "B" %}

  <!-- Paint Window (big, date-focused) -->
  <div class="win paint" style="top:14px; left:14px;">
    <div class="win-tb">
      <div class="win-close"></div>
      <span class="win-t">{{ date_str }}</span>
    </div>
    <div style="position:relative;">
      <div class="paint-toolbar"></div>
      <div class="paint-body">
        <div class="paint-temp">{{ temp }}{{ unit }}</div>
        <div class="paint-wx">{{ wx }}</div>
        <div class="paint-forecast">
          Today: High {{ today_hi }}° / Low {{ today_lo }}°<br>
          Tomorrow: High {{ tmrw_hi }}° / Low {{ tmrw_lo }}°
        </div>
      </div>
    </div>
  </div>

  <!-- Moon DA / Puzzle / Calculator (bottom-right area) -->
  {% if show_moon %}
  <div class="win moon-da" style="bottom:14px; right:70px;">
    <div class="win-tb">
      <div class="win-close"></div>
      <span class="win-t">Moon Phase</span>
    </div>
    <div class="moon-da-body">
      <img src="{{ CDN }}/moon/moon{{ moon_img_idx }}.png" alt="{{ moon_label }}">
      <div class="moon-da-text">{{ moon_label }}<br>Day {{ moon_phase }} of 29</div>
    </div>
  </div>
  {% elsif da_alt == 0 %}
  <img class="da-img" src="{{ CDN }}/puzzle.png" alt="Puzzle" style="position:absolute; bottom:14px; right:70px; width:91px; height:auto; image-rendering:pixelated;">
  {% else %}
  <img class="da-img" src="{{ CDN }}/calculator.png" alt="Calculator" style="position:absolute; bottom:14px; right:70px; width:106px; height:auto; image-rendering:pixelated;">
  {% endif %}

{% comment %} ════════════════════════════════════════════════════
   LAYOUT C — Write Window (left) + Moon DA (top-right) + Icon Window (bottom-right)
   Shown 1 of 7 days. Text-editor style.
   ════════════════════════════════════════════════════ {% endcomment %}
{% elsif layout == "C" %}

  <!-- Write Window -->
  <div class="win write" style="top:14px; left:14px;">
    <div class="win-tb">
      <div class="win-close"></div>
      <span class="win-t">{{ date_str }}</span>
    </div>
    <div class="write-ruler"></div>
    <div class="write-body">
      <div class="write-title-line">Weather for {{ day_name }}</div>
      <div class="write-line">Currently: {{ temp }}{{ unit }}, {{ wx }}</div>
      <div class="write-line">Today: High {{ today_hi }}° / Low {{ today_lo }}°</div>
      <div class="write-line">Tomorrow: High {{ tmrw_hi }}° / Low {{ tmrw_lo }}°</div>
    </div>
  </div>

  <!-- Moon DA (top-right area) -->
  {% if show_moon %}
  <div class="win moon-da" style="top:14px; right:70px;">
    <div class="win-tb">
      <div class="win-close"></div>
      <span class="win-t">Moon Phase</span>
    </div>
    <div class="moon-da-body">
      <img src="{{ CDN }}/moon/moon{{ moon_img_idx }}.png" alt="{{ moon_label }}">
      <div class="moon-da-text">{{ moon_label }}<br>Day {{ moon_phase }} of 29</div>
    </div>
  </div>
  {% endif %}

  <!-- Icon Window (3×2, bottom-right) -->
  <div class="win icon-win" style="bottom:14px; right:70px;">
    <div class="win-tb">
      <div class="win-close"></div>
      <span class="win-t">{{ win_title }}</span>
    </div>
    <div class="icon-row">
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic0 }}.png" alt=""></div>
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic1 }}.png" alt=""></div>
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic2 }}.png" alt=""></div>
    </div>
    <div class="icon-row">
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic3 }}.png" alt=""></div>
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic4 }}.png" alt=""></div>
      <div class="icon-cell"><img src="{{ CDN }}/icons/icon_{{ icon_cat }}{{ ic5 }}.png" alt=""></div>
    </div>
  </div>

{% endif %}

</div><!-- /desktop -->
</div><!-- /screen -->

